{
  "compilerOptions": {
    "target":              "ES2022",
    "module":              "Node16",
    "moduleResolution":    "Node16",
    "esModuleInterop":     true,
    "strict":              true,
    "resolveJsonModule":   true,
    "allowSyntheticDefaultImports": true,
    "outDir":              "dist"
  },
  "ts-node": {
    "esm":                 true,
    "experimentalSpecifierResolution": "node"
  },
  "include": [
    "hardhat.config.ts",
    "test/**/*.ts",
    "scripts/**/*.ts",
    "scripts/exportABI.js"  ]
}